{
  "name": "vole",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenClaw-inspired personal general-purpose agent for learning and real use.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "cli": "tsx --env-file=.env apps/cli/src/index.ts",
    "docs:check": "tsx scripts/check-docs.ts",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "check": "pnpm run typecheck && pnpm run test && pnpm run docs:check"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
