# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# ── Model Provider (choose one) ──────────────────────────────────────────────

# Anthropic (uses claude-haiku-4-5 by default)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter (model name required)
# OPENROUTER_API_KEY=sk-or-...
# PEEWIT_MODEL=anthropic/claude-3-haiku

# Any OpenAI-compatible endpoint
# PEEWIT_API_KEY=...
# PEEWIT_BASE_URL=https://your-provider/v1
# PEEWIT_MODEL=your-model-name

# ── Runtime ───────────────────────────────────────────────────────────────────

# Autonomy mode: observe | confirm | auto  (default: confirm)
# PEEWIT_DEFAULT_MODE=confirm

# Working directory  (default: current directory)
# PEEWIT_WORKSPACE_ROOT=.

# Prompt rendering: full | minimal | none  (default: full)
# PEEWIT_PROMPT_MODE=full

# Execution discipline: default | strict-agentic  (default: default)
# PEEWIT_EXECUTION_CONTRACT=default

# Tool capability set: coding | full | messaging | background  (default: full)
# PEEWIT_TOOL_PROFILE=full

# Restrict shell to workspace root: true | false  (default: false)
# PEEWIT_SANDBOX=false

# ── Memory ────────────────────────────────────────────────────────────────────

# Memory policy: disabled | read-only | write  (default: disabled)
# PEEWIT_LONG_TERM_MEMORY=disabled

# ── Model Tuning ─────────────────────────────────────────────────────────────

# Anthropic reasoning depth: off | minimal | low | medium | high | max | adaptive
# PEEWIT_THINKING_BUDGET=adaptive
