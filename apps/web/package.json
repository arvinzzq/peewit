{
  "name": "@arvinclaw/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "concurrently \"tsx watch src/server.ts\" \"vite --port 5173\"",
    "start": "node dist/server.js",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@arvinclaw/config": "workspace:*",
    "@arvinclaw/context": "workspace:*",
    "@arvinclaw/core": "workspace:*",
    "@arvinclaw/models": "workspace:*",
    "@arvinclaw/sessions": "workspace:*",
    "@arvinclaw/skills": "workspace:*",
    "@arvinclaw/tools": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "hono": "^4.7.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "vite": "^6.3.5"
  }
}
